{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodedash.dev/schemas/graph-spec.schema.json",
  "title": "NodeDash Workspace Specification",
  "description": "The compiled output of the onboarding questionnaire. One object drives the canvas render, the database seeding, and every agent's initialization. Use for constrained decoding and validation so malformed graphs fail loudly.",
  "type": "object",
  "required": ["workspace", "nodes", "edges", "agent_guardrails"],
  "additionalProperties": false,
  "properties": {
    "workspace": {
      "type": "object",
      "required": ["workspace_name", "industry", "global_objective", "trigger_event", "standard_sla_days"],
      "additionalProperties": false,
      "properties": {
        "workspace_name": { "type": "string", "minLength": 1 },
        "industry": { "type": "string", "minLength": 1 },
        "global_objective": { "type": "string", "minLength": 1 },
        "trigger_event": { "type": "string", "minLength": 1 },
        "standard_sla_days": { "type": "integer", "minimum": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["node_id", "name", "type", "responsibilities", "constraints", "autonomy_level", "agent_system_prompt"],
        "additionalProperties": false,
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^node_[a-z0-9_]+$"
          },
          "name": { "type": "string", "minLength": 1 },
          "type": { "enum": ["internal", "external"] },
          "responsibilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "constraints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "autonomy_level": {
            "enum": ["suggest_only", "execute", "restricted"],
            "description": "suggest_only: drafts actions, human confirms. execute: may auto-approve/act on standard requests. restricted: external agent with limited scope and visibility."
          },
          "agent_system_prompt": {
            "type": "string",
            "minLength": 1,
            "description": "The AI Chief of Staff system prompt for this node, filled from the node's role, responsibilities, constraints, autonomy, visibility, and exception protocol."
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["edge_id", "source_node_id", "target_node_id", "action_type", "required_data_payload"],
        "additionalProperties": false,
        "properties": {
          "edge_id": {
            "type": "string",
            "pattern": "^edge_[a-z0-9_]+$"
          },
          "source_node_id": {
            "type": "string",
            "pattern": "^node_[a-z0-9_]+$",
            "description": "Must match a node_id in nodes."
          },
          "target_node_id": {
            "type": "string",
            "pattern": "^node_[a-z0-9_]+$",
            "description": "Must match a node_id in nodes."
          },
          "action_type": {
            "type": "string",
            "minLength": 1,
            "description": "The semantic of the connection, e.g. request_approval, send_authorization, send_order, status_update."
          },
          "required_data_payload": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Documents/data that must accompany this handoff."
          }
        }
      }
    },
    "agent_guardrails": {
      "type": "object",
      "required": ["delay_handling_protocol", "vendor_data_transparency", "communication_tone"],
      "additionalProperties": false,
      "properties": {
        "delay_handling_protocol": {
          "enum": ["auto-renegotiate-then-alert", "alert-human-only", "halt-downstream"]
        },
        "vendor_data_transparency": {
          "enum": ["strict_isolation", "shared_deadlines", "full_transparency"]
        },
        "communication_tone": {
          "enum": ["professional_and_concise", "friendly_and_detailed", "formal"]
        }
      }
    }
  }
}
