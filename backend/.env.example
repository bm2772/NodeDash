# Copy to .env and fill in. All values have sensible dev defaults.

# --- Auth ---
JWT_SECRET=change-me-in-prod
JWT_EXP_HOURS=12

# --- Database ---
# Defaults to a local sqlite file (backend/nodedash.db)
# DATABASE_URL=postgresql+psycopg://user:pass@host/db

# --- LLM provider ---
# LLM_PROVIDER: auto | fireworks | amd | mock
#   auto  -> use the configured endpoint if LLM_API_KEY (or base url) is set, else mock
#   mock  -> no network; builds the graph heuristically from the answers (great for offline demos)
LLM_PROVIDER=auto

# Fireworks AI (OpenAI-compatible)
#   LLM_BASE_URL=https://api.fireworks.ai/inference/v1
#   LLM_MODEL=accounts/fireworks/models/qwen2p5-72b-instruct
#   LLM_API_KEY=fw_...    (or set FIREWORKS_API_KEY)

# AMD cloud (vLLM + ROCm serving Qwen, OpenAI-compatible)
#   LLM_PROVIDER=amd
#   LLM_BASE_URL=http://<amd-host>:8000/v1
#   LLM_MODEL=Qwen/Qwen2.5-32B-Instruct
#   LLM_API_KEY=EMPTY

LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/qwen3-...
LLM_API_KEY=
LLM_TIMEOUT=60
# Qwen3 thinks by default; /no_think keeps replies fast + clean (set false for non-Qwen)
LLM_NO_THINK=true

# --- RAG (per-node semantic cache of past agent Q&A) ---
# Set an embedding model to enable it; unset/mock disables it cleanly.
LLM_EMBED_MODEL=            # e.g. nomic-embed-text (ollama) | nomic-ai/nomic-embed-text-v1.5 (fireworks)
RAG_ENABLED=true
RAG_TOP_K=3
RAG_THRESHOLD=0.80

# --- On-demand AMD MI300X GPU (Option B tiered fallback) ---
# The LLM_* above is the always-on fallback; GPU_* is the GPU that wakes on demand.
# Leave GPU_MANAGE=false to just use the fallback (default). See DEPLOY.md.
GPU_MANAGE=false
GPU_MODEL=Qwen/Qwen3-32B
GPU_API_KEY=
GPU_IDLE_MINUTES=15
GPU_VLLM_PORT=8000
# GPU_BASE_URL=http://<reserved-ip>:8000/v1   # optional; else resolved from the created droplet
# DigitalOcean droplet lifecycle (AMD Dev Cloud runs on DO):
DO_API_TOKEN=
DO_GPU_SNAPSHOT_ID=
DO_GPU_SIZE=gpu-mi300x1-192gb
DO_REGION=atl1
DO_SSH_KEY_IDS=

# --- CORS (frontend origin) ---
CORS_ORIGINS=*
